# 复制为 backend/.env.docker 或服务器上的 /opt/courseagent/backend.env

APP_NAME=courseagent-backend
DEBUG=false
HOST=0.0.0.0
PORT=8080

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_SECONDS=86400
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=change-me-admin-password

# 指向已有 PostgreSQL 容器（同一 docker network 内用容器名）
# 例：docker network connect courseagent <你的postgres容器名>
DATABASE_URL=postgresql+psycopg2://postgres:password@postgres:5432/course

# 浏览器访问前端的来源（公网 IP / 域名）
CORS_ORIGINS=http://127.0.0.1,http://localhost

STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=/app/data/attachments
LOCAL_STORAGE_BUCKET=course-attachments
FAISS_INDEX_PATH=/app/data/vector_index
MILVUS_LITE_PATH=/app/data/milvus_qibiao.db

# 轻量镜像请保持 false；全量镜像（Dockerfile.ml）可改为 true
EMBEDDING_MODE=inline
EMBEDDING_ENABLED=false
EMBEDDING_MODEL=models/bge-small-zh-v1.5
EMBEDDING_VECTOR_STORE=milvus
EMBEDDING_INDEX_BATCH_SIZE=64
INDEX_AUTO_ON_CHUNK=false

LLM_ENABLED=true
DOUBAO_MODEL_NAME=doubao-seed-2-0-pro-260215
DOUBAO_ENDPOINT_ID=
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_TIMEOUT_SECONDS=120
QA_RETRIEVAL_TOP_K=8

DOCLING_WORKER_ENABLED=false
