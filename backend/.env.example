APP_NAME=courseagent-backend
DEBUG=true
HOST=0.0.0.0
PORT=8080
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
JWT_SECRET=change-me-in-production
JWT_EXPIRE_SECONDS=86400
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=admin123

# PostgreSQL（course 数据库）
DATABASE_URL=postgresql+psycopg2://postgres:password@127.0.0.1:5432/course

# 对象存储（POC 默认本地目录，无需 MinIO）
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=./data/attachments
LOCAL_STORAGE_BUCKET=course-attachments
# 若需切回 MinIO：STORAGE_BACKEND=minio 并配置下列项
# MINIO_ENDPOINT=127.0.0.1:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=course-attachments
# MINIO_SECURE=false

# SPRS（同步任务使用，按需填写）
SPRS_BASE_URL=https://srms.foton.com.cn
SPRS_TIMEOUT_SECONDS=60
SPRS_PAGE_SIZE=50
SPRS_DEFAULT_STAND_TYPE=INLAND
SPRS_DOWNLOAD_ATTACHMENTS=true

# Docling Worker（扫描件 PDF 走 HTTP 解析，需先启动 ocr-poc/docling/run_worker.ps1）
DOCLING_WORKER_ENABLED=false
DOCLING_WORKER_URL=http://127.0.0.1:8090
DOCLING_WORKER_OCR=true
DOCLING_WORKER_DESCRIBE_FIGURES=true
DOCLING_WORKER_TIMEOUT_SECONDS=3600
# DOCLING_WORKER_TOKEN=
# DOCLING_WORKER_DEVICE=cuda
DOCLING_FALLBACK_ON_NO_TEXT_LAYER=true
DOCLING_FALLBACK_ON_LIKELY_SCANNED=false

# 向量索引（默认进程内向量化；Windows 默认 FAISS，Linux 默认 Milvus Lite）
EMBEDDING_MODE=inline
EMBEDDING_ENABLED=true
# 本机模型目录（相对 backend 根目录）；未设置且存在 models/bge-small-zh-v1.5 时会自动使用
EMBEDDING_MODEL=models/bge-small-zh-v1.5
# 也可填 HuggingFace 模型 ID：BAAI/bge-small-zh-v1.5
# EMBEDDING_VECTOR_STORE=faiss
# FAISS_INDEX_PATH=./data/vector_index
# MILVUS_LITE_PATH=./data/milvus_qibiao.db
EMBEDDING_INDEX_BATCH_SIZE=64
INDEX_AUTO_ON_CHUNK=false

# 可选：独立 Embedding Worker（EMBEDDING_MODE=worker 时使用）
# EMBEDDING_WORKER_ENABLED=true
# EMBEDDING_WORKER_URL=http://127.0.0.1:8091
# EMBEDDING_WORKER_TIMEOUT_SECONDS=600
# EMBEDDING_WORKER_TOKEN=

# 豆包 LLM（标准问答，火山方舟 Ark API）
LLM_ENABLED=true
DOUBAO_MODEL_NAME=doubao-seed-2-0-pro-260215
DOUBAO_ENDPOINT_ID=
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_TIMEOUT_SECONDS=120
QA_RETRIEVAL_TOP_K=8
